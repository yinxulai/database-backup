{
  "name": "@yinxulai/database-backup",
  "version": "0.1.0",
  "description": "Multi-mode database backup tool with CI-first architecture",
  "type": "module",
  "main": "./output/index.js",
  "bin": {
    "backup": "./output/cli/run.js"
  },
  "exports": {
    ".": "./output/index.js",
    "./cli": "./output/cli/index.js"
  },
  "files": [
    "output/"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:dev": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "build:sea": "node scripts/build-sea.mjs",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e",
    "clean": "rm -rf output sea out",
    "lint": "eslint source --ext .ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "yaml": "^2.0.0",
    "cron-parser": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "database",
    "backup",
    "postgresql",
    "mysql",
    "s3",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yinxulai/database-backup.git"
  }
}
