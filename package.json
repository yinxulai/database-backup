{
  "name": "@yinxulai/database-backup",
  "version": "0.1.0",
  "description": "Multi-mode database backup tool with CI-first architecture",
  "type": "module",
  "bin": {
    "backup": "./source/cli/run.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "tsx source/cli/run.ts",
    "backup": "tsx source/cli/run.ts",
    "lint": "eslint source --ext .ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "database",
    "backup",
    "postgresql",
    "mysql",
    "s3",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yinxulai/database-backup.git"
  }
}
