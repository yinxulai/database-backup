{
  "name": "@yinxulai/database-backup",
  "version": "0.1.0",
  "description": "Multi-mode database backup tool with CI-first architecture",
  "type": "module",
  "bin": {
    "backup": "./source/cli/run.ts"
  },
  "exports": {
    ".": "./source/index.ts",
    "./cli": "./source/cli/run.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsx source/cli/run.ts",
    "build:sea": "node scripts/build-sea.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint source --ext .ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "cron-parser": "^4.0.0",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "database",
    "backup",
    "postgresql",
    "mysql",
    "s3",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yinxulai/database-backup.git"
  }
}
